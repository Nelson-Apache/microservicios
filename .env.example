# ═══════════════════════════════════════════════════════════════════════════
# EJEMPLO DE CONFIGURACIÓN DE VARIABLES DE ENTORNO
# ═══════════════════════════════════════════════════════════════════════════
# 
# Instrucciones:
# 1. Copiar este archivo como '.env' en la raíz del proyecto
# 2. Actualizar los valores según tu entorno de desarrollo/producción
# 3. NUNCA subir el archivo .env al repositorio (ya está en .gitignore)
#

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DATOS - Empleados
# ─────────────────────────────────────────────────────────────────────────────
EMPLEADOS_DB_USER=postgres
EMPLEADOS_DB_PASSWORD=postgres_secure_password_change_me
EMPLEADOS_DB_NAME=empleadosdb
EMPLEADOS_DB_HOST=database-empleados
EMPLEADOS_DB_PORT=5432

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DATOS - Departamentos
# ─────────────────────────────────────────────────────────────────────────────
DEPARTAMENTOS_DB_USER=postgres
DEPARTAMENTOS_DB_PASSWORD=postgres_secure_password_change_me
DEPARTAMENTOS_DB_NAME=departamentosdb
DEPARTAMENTOS_DB_HOST=database-departamentos
DEPARTAMENTOS_DB_PORT=5432

# ─────────────────────────────────────────────────────────────────────────────
# SERVICIO DE EMPLEADOS (Python/FastAPI)
# ─────────────────────────────────────────────────────────────────────────────
EMPLEADOS_SERVICE_PORT=8000
# URL construida: postgresql://${EMPLEADOS_DB_USER}:${EMPLEADOS_DB_PASSWORD}@${EMPLEADOS_DB_HOST}:${EMPLEADOS_DB_PORT}/${EMPLEADOS_DB_NAME}

# ─────────────────────────────────────────────────────────────────────────────
# SERVICIO DE DEPARTAMENTOS (Java/Spring Boot)
# ─────────────────────────────────────────────────────────────────────────────
DEPARTAMENTOS_SERVICE_PORT=8080
# URL construida: jdbc:postgresql://${DEPARTAMENTOS_DB_HOST}:${DEPARTAMENTOS_DB_PORT}/${DEPARTAMENTOS_DB_NAME}

# ─────────────────────────────────────────────────────────────────────────────
# SERVICIO DE NOTIFICACIONES (Node.js/Express)
# ─────────────────────────────────────────────────────────────────────────────
NOTIFICACIONES_SERVICE_PORT=3000
NODE_ENV=production

# ─────────────────────────────────────────────────────────────────────────────
# SERVICIO DE REPORTES (Go)
# ─────────────────────────────────────────────────────────────────────────────
REPORTES_SERVICE_PORT=3000

# ─────────────────────────────────────────────────────────────────────────────
# URLs DE COMUNICACIÓN ENTRE SERVICIOS
# ─────────────────────────────────────────────────────────────────────────────
EMPLEADOS_SERVICE_URL=http://empleados-service:8000
DEPARTAMENTOS_SERVICE_URL=http://departamentos-service:8080

# ─────────────────────────────────────────────────────────────────────────────
# SEGURIDAD JWT — Reto 4
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANTE: Cambiar este valor en producción. Debe ser una cadena larga y aleatoria.
# Esta misma clave es usada por auth-service (firma) y api-gateway (verificación).
# Solo se documenta aquí con fines académicos.
JWT_SECRET=changeme-super-secret-key-for-dev

# Tiempo de expiración de los tokens (en minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=60
RESET_TOKEN_EXPIRE_MINUTES=60

# ─────────────────────────────────────────────────────────────────────────────
# API GATEWAY
# ─────────────────────────────────────────────────────────────────────────────
GATEWAY_PORT=8000

# ─────────────────────────────────────────────────────────────────────────────
# SERVICIO DE AUTENTICACIÓN (Python/FastAPI)
# ─────────────────────────────────────────────────────────────────────────────
AUTH_SERVICE_PORT=8085

# BASE DE DATOS - Auth
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=postgres_secure_password_change_me
AUTH_DB_NAME=authdb

# Usuario administrador semilla (creado automáticamente al iniciar auth-service)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@empresa.com

# ─────────────────────────────────────────────────────────────────────────────
# SEGURIDAD Y LOGGING
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Valores posibles: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ─────────────────────────────────────────────────────────────────────────────
# NOTAS IMPORTANTES
# ─────────────────────────────────────────────────────────────────────────────
# - En producción, usar contraseñas seguras y complejas
# - Cambiar JWT_SECRET por una cadena aleatoria de al menos 32 caracteres
# - Considerar usar gestores de secretos (AWS Secrets Manager, Azure Key Vault, etc.)
# - Rotar credenciales periódicamente
# - No usar las contraseñas de ejemplo en entornos reales
